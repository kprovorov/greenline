# Supabase
# Clerk must also be enabled as a Third-Party Auth provider in the Supabase
# Dashboard (Authentication -> Sign In / Providers) — see
# packages/supabase/README.md. No extra env vars are needed for that step.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
